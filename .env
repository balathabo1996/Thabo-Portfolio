# =============================================================================
# Environment Variables  —  .env
# =============================================================================
# Sensitive configuration loaded at runtime by Next.js.
# NEVER commit this file to version control — it is listed in .gitignore.
# Copy this file to .env.local for local development.
# =============================================================================

# --- MongoDB Atlas Connection ---
# Full connection string for the MongoDB Atlas cluster.
# Format: mongodb+srv://<user>:<password>@<cluster-host>/<optional-db>
MONGO_URI=mongodb+srv://balathabo96:Thabo%401996@cluster0.cerulqu.mongodb.net

# Name of the MongoDB database to use within the Atlas cluster.
MONGO_DB=Thabo-Portfolio

# Name of the collection used to store resume documents (PDF binary data).
MONGO_COLLECTION=Resume

# --- Admin API Security ---
# Secret key required in the x-api-key header to authorise PUT /api/profile.
# Change this to a strong random string before deploying to production.
ADMIN_API_KEY=Thabo@1996

# --- Email / SMTP Credentials ---
# Gmail account used to send contact-form notification emails.
EMAIL_USER=balathabo96@gmail.com

# Gmail App Password (not the account password).
# Generate one at: Google Account → Security → App Passwords.
EMAIL_PASS=ensn fkvl uyys qegh
