{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Thabo Portfolio API",
    "description": "Complete Postman collection for the Thabo.Portfolio REST API (v2).\n\nArchitecture:\n  - Profile Image → Cloudinary (POST /api/upload)\n  - Resume        → Google Drive shareable link (stored as resumeUrl in profile)\n  - Admin UI      → http://localhost:3000/admin (protected by x-api-key)\n\nEndpoints:\n  GET  /api/profile             – Fetch owner profile\n  PUT  /api/profile             – Update profile fields (x-api-key required)\n  POST /api/upload              – Upload profile image to Cloudinary (x-api-key required)\n  GET  /api/experience          – Fetch experience entries\n  POST /api/experience          – Add new experience (x-api-key required)\n  PUT  /api/experience          – Update experience entry\n  DELETE /api/experience        – Delete experience entry\n  GET  /api/projects            – Fetch portfolio projects\n  POST /api/projects            – Add new project (x-api-key required)\n  PUT  /api/projects            – Update project\n  DELETE /api/projects          – Delete project\n  GET  /api/skills              – Fetch skills\n  POST /api/skills              – Add new skill (x-api-key required)\n  PUT  /api/skills              – Update skill\n  DELETE /api/skills            – Delete skill\n  POST /api/contact             – Send contact form email\n  POST /api/analytics/resume    – Track resume view click\n  GET  /api/analytics/resume     – Get resume download count\n  POST /api/seed                – Reset and seed database (x-api-key required)\n  GET  /api/swagger             – Raw OpenAPI JSON spec\n  GET  /api-docs                – Swagger UI page",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL. Swap to production URL when testing the deployed app."
    },
    {
      "key": "admin_api_key",
      "value": "",
      "type": "secret",
      "description": "Value of ADMIN_API_KEY from .env — required for all write operations."
    }
  ],
  "item": [
    {
      "name": "Profile",
      "description": "Manages the single owner-profile document stored in MongoDB.",
      "item": [
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns profile object', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('_id');",
                  "    pm.expect(json).to.have.property('firstName');",
                  "    pm.expect(json).to.have.property('profileImageUrl');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "profile"]
            },
            "description": "Returns the profile document from MongoDB."
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Balachandran\",\n  \"lastName\": \"Thabotharan\",\n  \"title\": \"Infrastructure Engineer | IT Solutions Professional\",\n  \"role\": \"Infrastructure Engineer\",\n  \"bio\": \"Experienced IT professional specialising in infrastructure and cybersecurity.\",\n  \"missionDescription\": \"My professional mission is to build resilient, secure IT infrastructures.\",\n  \"location\": \"Scarborough, Ontario, Canada\",\n  \"email\": \"balathabo96@gmail.com\",\n  \"phone\": \"(437) 383-1996\",\n  \"linkedinUrl\": \"https://www.linkedin.com/in/balachandran-thabotharan-261895131\",\n  \"githubUrl\": \"https://github.com/balathabo1996\",\n  \"profileImageUrl\": \"https://res.cloudinary.com/dk4kvk0kw/image/upload/v1/thabo-portfolio/profileImageUrl.png\",\n  \"resumeUrl\": \"https://drive.google.com/file/d/1sIfIHXwJ8njSlHbxFtOxpSGj6fCbKsJ0/view?usp=sharing\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "profile"]
            },
            "description": "Updates profile fields. Requires x-api-key."
          },
          "response": []
        },
        {
          "name": "Upload Profile Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "Select an image file" },
                { "key": "field", "value": "profileImageUrl", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "upload"]
            },
            "description": "Uploads an image to Cloudinary. Requires x-api-key."
          },
          "response": []
        }
      ]
    },
